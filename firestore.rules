rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the requester is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to verify user owns the document being accessed
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Users collection rules
    match /users/{userId} {
      // Users can read and write their own user profile documents
      allow read, write: if isOwner(userId);
      
      // Admins are authorized to view all profiles for rankings and dashboard reports
      allow read: if isAuthenticated() && request.auth.token.role == 'admin';
    }

    // 2. Quizzes historical records rules
    match /quizzes/{quizId} {
      // Authenticated users can read their own quiz results
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      
      // Authenticated users can log new quiz scores
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      
      // Skip updates/deletes to guarantee integrity of records
      allow update, delete: if false;
    }

    // 3. AI history queries and conversations logs
    match /ai_history/{logId} {
      // Authenticated users can read their own AI chat logs
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      
      // Authenticated users can append new conversations
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      
      // Do not allow updating or deleting historical logs
      allow update, delete: if false;
    }
  }
}
